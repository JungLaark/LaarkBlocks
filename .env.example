# LaarkBlocks 환경 설정 예시 — 복사해서 .env 로 사용
# ---------------------------------------------------------------

# Ollama 서버 주소 (로컬 sLLM)
LAARK_OLLAMA_BASE_URL=http://localhost:11434

# 외부 API provider 사용 시 (선택)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# CORS 허용 오리진 (콤마 구분, 빌더 스튜디오 개발 서버 등)
LAARK_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 에이전트 프리셋(JSON) 디렉터리
LAARK_AGENT_PRESET_DIR=configs/agents

# 실행 이력(트레이스) 저장소 — 운영 전환 시 postgresql+asyncpg://... 로 교체
LAARK_DATABASE_URL=sqlite+aiosqlite:///./laarkblocks.db

# 모델 토큰 단가표 오버라이드 (선택, USD per 1M tokens)
LAARK_PRICING_CONFIG_PATH=configs/model_pricing.json
